# ── Supabase ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Mail credential encryption ───────────────────────────────────────────
# 32-byte base64 key for AES-256-GCM at-rest encryption of IMAP/SMTP
# passwords. Generate with:  openssl rand -base64 32
# Losing this key means every user must re-enter their mail passwords.
CREDENTIALS_KEY=

# ── Stripe (optional in dev; app boots without billing configured) ───────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO=
STRIPE_PRICE_BUILDER=
STRIPE_PRICE_EMPIRE=

# ── App ──────────────────────────────────────────────────────────────────
PORT=8080
# Comma-separated allowed dashboard origins (unset = allow all; JWT still required)
CORS_ORIGINS=
# Absolute URL of the deployed dashboard (checkout redirects, email links)
DASHBOARD_URL=http://localhost:5173

# ── Sync tuning ──────────────────────────────────────────────────────────
MAIL_RETENTION_DAYS=90
MAIL_RETENTION_MAX_PER_ACCOUNT=500
INITIAL_SYNC_LIMIT=200

# ── Web (Vercel env, not read by the API) ────────────────────────────────
VITE_SUPABASE_URL=https://YOURPROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=http://localhost:8080
