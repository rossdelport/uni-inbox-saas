node_modules/
dist/
# The top-level dist/ is the committed, prebuilt dashboard that Vercel serves
# as-is with no build step (see vercel.json), so deploys cannot fail.
# Rebuild + refresh it with: npm run site:build
!/dist/
!/dist/**
.env
.env.*
!.env.example
*.log
.DS_Store
.vercel
.vite
*.tsbuildinfo
